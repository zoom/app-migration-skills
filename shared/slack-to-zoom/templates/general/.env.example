# Server Configuration
PORT=3000
NODE_ENV=development

# App Identity
APP_NAME=Zoom Chatbot

# Zoom Credentials
# Get these from https://marketplace.zoom.us/develop/create
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here
ZOOM_BOT_JID=your_bot_jid@xmpp.zoom.us
# For dev environment, use: your_bot_jid@xmppdev.zoom.us
ZOOM_WEBHOOK_SECRET_TOKEN=your_webhook_secret_token

# API Endpoints (AUTO-DETECTED from Bot JID - usually don't need to set these)
# Production JID (@xmpp.zoom.us) auto-uses:
#   ZOOM_API_HOST=https://api.zoom.us
#   ZOOM_OAUTH_HOST=https://zoom.us
# Development JID (@xmppdev.zoom.us) auto-uses:
#   ZOOM_API_HOST=https://zoomdev.us
#   ZOOM_OAUTH_HOST=https://zoomdev.us
# Only uncomment to override auto-detection

# OAuth Redirect URI
# Update this with your public domain (use ngrok URL for local dev)
ZOOM_REDIRECT_URI=https://your-domain.com/api/zoomapp/auth

# ============================================
# OPTIONAL: Live API Testing (E2E Tests)
# ============================================
# These credentials are ONLY needed if you want to run live API tests
# with real Zoom API calls (npm run test:e2e).
#
# Unit and integration tests (npm test) use mocks and don't need these.
#
# Requirements:
# - TEST_CHANNEL_JID: A dedicated Zoom channel for test messages
#   (Get this from your Zoom channel URL or via API)
# - TEST_ACCOUNT_ID: Your Zoom account ID
#   (Get from marketplace.zoom.us → Your App → App Credentials)
#
# WARNING: E2E tests will send REAL messages to this channel!
# Use a dedicated test channel to avoid spam.

# TEST_CHANNEL_JID=channel_abc123@conference.xmpp.zoom.us
# TEST_ACCOUNT_ID=your_account_id_here
