{
  "name": "poker-planner-zoom",
  "version": "1.0.0",
  "description": "Planning Poker for Zoom Team Chat - Migrated from Slack",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:e2e": "jest tests/e2e --testPathIgnorePatterns=/node_modules/ --runInBand",
    "test:all": "jest --runInBand"
  },
  "keywords": ["zoom", "chatbot", "team-chat"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "dotenv": "^16.3.1",
    "axios": "^1.6.0",
    "crypto": "^1.0.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.4.5",
    "jest": "^29.5.0",
    "ts-jest": "^29.1.0",
    "typescript": "^5.1.6",
    "ts-node-dev": "^2.0.0"
  }
}
