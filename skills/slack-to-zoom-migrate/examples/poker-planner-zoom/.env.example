# Server Configuration
PORT=3000
NODE_ENV=development

# App Identity
APP_NAME=Planning Poker

# Zoom Credentials (get from marketplace.zoom.us)
ZOOM_CLIENT_ID=your_client_id_here
ZOOM_CLIENT_SECRET=your_client_secret_here
ZOOM_BOT_JID=your_bot_jid@xmpp.zoom.us
ZOOM_WEBHOOK_SECRET_TOKEN=your_webhook_secret_here

# API Endpoints
# For production: https://api.zoom.us and https://zoom.us
# For development: https://zoomdev.us and https://zoomdev.us
ZOOM_API_HOST=https://api.zoom.us
ZOOM_OAUTH_HOST=https://zoom.us

# OAuth Redirect URI (your public domain + /api/zoomapp/auth)
# For local testing: http://localhost:3000/api/zoomapp/auth
# For production: https://your-domain.com/api/zoomapp/auth
ZOOM_REDIRECT_URI=http://localhost:3000/api/zoomapp/auth
